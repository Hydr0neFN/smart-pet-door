#include <SPI.h>
#include <TMCStepper.h>
#include <FastAccelStepper.h>

// ── Pins ─────────────────────────────────────────────────
#define STEP_PIN    25
#define DIR_PIN     26
#define EN_PIN      27
#define CS_PIN       5
#define SCK_PIN     18
#define MISO_PIN    19
#define MOSI_PIN    23
#define DIAG1_PIN   34   // ← StallGuard signal from TMC2130

// ── Driver config ─────────────────────────────────────────
#define R_SENSE     0.11f
#define RMS_CURRENT 2000
#define MICROSTEPS  16
#define STEPS_PER_REV (200 * MICROSTEPS)

// ── StallGuard threshold ──────────────────────────────────
// Range: -64 to +63. Lower = more sensitive (triggers easier).
// Start at 10 and tune — block the motor by hand to test.
#define SGT_VALUE  50

// ── Objects ───────────────────────────────────────────────
TMC2130Stepper driver(CS_PIN, R_SENSE);
FastAccelStepperEngine engine = FastAccelStepperEngine();
FastAccelStepper *stepper = NULL;

volatile bool stallDetected = false;

void IRAM_ATTR onStall() {
  stallDetected = true;
}

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n--- TMC2130 + StallGuard startup ---");

  pinMode(EN_PIN, OUTPUT);
  digitalWrite(EN_PIN, LOW);

  // DIAG1 interrupt — fires when stall is detected
  pinMode(DIAG1_PIN, INPUT);
  attachInterrupt(digitalPinToInterrupt(DIAG1_PIN), onStall, RISING);

  SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, CS_PIN);
  driver.begin();

  driver.rms_current(RMS_CURRENT);
  driver.microsteps(MICROSTEPS);
  driver.en_pwm_mode(false);        // SpreadCycle — required for StallGuard
  driver.sgt(SGT_VALUE);            // Stall sensitivity
  driver.diag1_stall(true);         // Route stall → DIAG1 pin
  driver.diag1_pushpull(true);      // DIAG1 as push-pull output
  driver.TCOOLTHRS(0xFFFFF);        // StallGuard active at all speeds

  uint8_t ver = driver.version();
  Serial.print("TMC2130 version: 0x");
  Serial.println(ver, HEX);
  if (ver != 0x11) {
    Serial.println("ERROR: Unexpected version — check wiring!");
    while (1);
  }
  Serial.println("Driver OK.");

  engine.init();
  stepper = engine.stepperConnectToPin(STEP_PIN);
  if (!stepper) {
    Serial.println("ERROR: Failed to init stepper pin!");
    while (1);
  }
  stepper->setDirectionPin(DIR_PIN);
  stepper->setSpeedInHz(800);
  stepper->setAcceleration(400);

  Serial.println("Ready. Block the motor shaft to test stall detection.");
}

void handleStall() {
  detachInterrupt(digitalPinToInterrupt(DIAG1_PIN));  // Stop re-triggering
  stepper->forceStop();
  Serial.println("⚠ Stall! Reversing...");
  delay(300);

  long pos = stepper->getCurrentPosition();
  stepper->moveTo(pos - STEPS_PER_REV);
  while (stepper->isRunning()) delay(1);

  Serial.println("Done reversing. Pausing...");
  delay(500);

  stallDetected = false;
  attachInterrupt(digitalPinToInterrupt(DIAG1_PIN), onStall, RISING);  // Re-arm
}

void loop() {
  stallDetected = false;

  Serial.println("→ Moving forward");
  stepper->moveTo(STEPS_PER_REV * 5);

  while (stepper->isRunning()) {
    if (stallDetected) {
      handleStall();
      return;
    }
    delay(1);
  }

  delay(1000);
  Serial.println("← Returning to start");
  stepper->moveTo(0);
  while (stepper->isRunning()) delay(1);
  delay(1000);
}